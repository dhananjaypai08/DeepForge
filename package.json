{
  "name": "deepforge",
  "version": "0.1.0",
  "private": true,
  "description": "DeepForge — the programming language & development environment for DeepBook Predict.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "cli": "pnpm --filter @deepforge/cli exec deepforge",
    "web": "pnpm --filter @deepforge/web dev",
    "keeper": "pnpm --filter @deepforge/keeper start"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "@mysten/sui": "1.45.2"
    }
  }
}
