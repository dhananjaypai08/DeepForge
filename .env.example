# DeepForge environment

# Sui network: "testnet" (default) | "mainnet" | "devnet" | "localnet"
DEEPFORGE_NETWORK=testnet

# Sui fullnode RPC override (optional; defaults to the public testnet fullnode)
# SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# Ed25519 private key (suiprivkey1... bech32) used by the CLI `apply`/`publish`
# and the keeper. NEVER commit a real key.
SUI_PRIVATE_KEY=

# OpenRouter API key for `deepforge intent` (NL -> IR). Server-side only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# DeepForge Strategy-object package id (filled in after `move` publish)
DEEPFORGE_PACKAGE_ID=

# Predict indexer base url (verify the live host before relying on it)
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
